generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String     @id @default(cuid())
  nombre    String
  slug      String     @unique
  plan      String     @default("FREE")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  users     User[]
  proyectos Proyecto[]

  @@map("organizations")
}

model User {
  id                  String            @id @default(cuid())
  email               String            @unique
  password            String
  nombre              String
  rol                 String            @default("VENDEDOR")
  orgId               String?
  whatsappNumber      String?
  aiAgentTone         String            @default("PROFESIONAL")
  useAiCopilot        Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  apellido            String?
  telefono            String?
  direccion           String?
  apodo               String?
  avatar              String?
  bio                 String?
  fechaNacimiento     DateTime?
  kycStatus           String            @default("PENDIENTE")
  configuracion       String?
  saldo               Decimal           @default(0) @db.Decimal(18, 2)
  demoEndsAt          DateTime?
  demoUsed            Boolean           @default(false)
  riskLevel           String            @default("low")
  riskReason          String?
  organization        Organization?     @relation(fields: [orgId], references: [id])
  bannersCreados      Banner[]          @relation("BannerCreador")
  documentacion       Documentacion[]
  historialAcciones   HistorialUnidad[]
  inversiones         Inversion[]       @relation("InversorInversion")
  leadsAsignados      Lead[]            @relation("LeadAsignado")
  noticiasEscritas    Noticia[]         @relation("NoticiaAutor")
  notificaciones      Notificacion[]
  pagos               Pago[]
  proyectosCreados    Proyecto[]        @relation("ProyectoCreador")
  reservasVendedor    Reserva[]         @relation("VendedorReserva")
  tareas              Tarea[]
  unidadesResponsable Unidad[]          @relation("ResponsableUnidad")
  auditLogs           AuditLog[]

  @@index([orgId])
  @@map("users")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g., "UPDATE_CONFIG", "DELETE_USER"
  entity    String   // e.g., "SystemConfig", "User"
  entityId  String?
  details   String?  // JSON string with changes or info
  ip        String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

model Proyecto {
  id                   String            @id @default(cuid())
  nombre               String
  slug                 String?           @unique
  descripcion          String?
  ubicacion            String?
  estado               String            @default("PLANIFICACION")
  tipo                 String            @default("URBANIZACION")
  orgId                String?
  imagenPortada        String?
  galeria              String?
  documentos           String?
  masterplanSVG        String?
  mapCenterLat         Float?            @default(-34.6037)
  mapCenterLng         Float?            @default(-58.3816)
  mapZoom              Int?              @default(16)
  overlayUrl           String?
  overlayBounds        String?
  overlayRotation      Float?            @default(0)
  invertible           Boolean           @default(false)
  precioM2Inversor     Decimal?          @db.Decimal(18, 2)
  precioM2Mercado      Decimal?          @db.Decimal(18, 2)
  metaM2Objetivo       Decimal?          @db.Decimal(18, 2)
  m2VendidosInversores Decimal           @default(0) @db.Decimal(18, 2)
  fechaLimiteFondeo    DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  documentacionEstado  String            @default("PENDIENTE")
  creadoPorId          String?
  aiKnowledgeBase      String?
  aiSystemPrompt       String?
  demoExpiresAt        DateTime?
  isDemo               Boolean           @default(false)
  requireKyc           Boolean           @default(true)
  visibilityStatus     String            @default("PUBLICADO")
  organization         Organization?     @relation(fields: [orgId], references: [id])
  documentacion        Documentacion[]
  etapas               Etapa[]
  hitosEscrow          EscrowMilestone[]
  inversiones          Inversion[]
  leads                Lead[]
  oportunidades        Oportunidad[]
  pagos                Pago[]
  archivosTecnicos     ProyectoArchivo[]
  imagenes             ProyectoImagen[]
  creadoPor            User?             @relation("ProyectoCreador", fields: [creadoPorId], references: [id])
  tareas               Tarea[]
  testimonios          Testimonio[]
  tours                Tour360[]
  infraestructuras     Infraestructura[]

  @@index([estado])
  @@index([createdAt])
  @@index([visibilityStatus])
  @@index([isDemo])
  @@index([tipo])
  @@index([orgId])
  @@map("proyectos")
}

model ProyectoArchivo {
  id                  String   @id @default(cuid())
  proyectoId          String
  tipo                String
  nombre              String
  url                 String
  visiblePublicamente Boolean  @default(false)
  createdAt           DateTime @default(now())
  proyecto            Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("proyecto_archivos")
}

model ProyectoImagen {
  id          String   @id @default(cuid())
  proyectoId  String
  url         String
  categoria   String
  esPrincipal Boolean  @default(false)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  proyecto    Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@index([orden])
  @@map("proyecto_imagenes")
}

model Inversion {
  id               String   @id @default(cuid())
  proyectoId       String
  inversorId       String
  m2Comprados      Decimal    @db.Decimal(18, 2)
  montoTotal       Decimal    @db.Decimal(18, 2)
  precioM2Aplicado Decimal    @db.Decimal(18, 2)
  estado           String   @default("ESCROW")
  hashTransaccion  String?
  fechaInversion   DateTime @default(now())
  updatedAt        DateTime @updatedAt
  inversor         User     @relation("InversorInversion", fields: [inversorId], references: [id], onDelete: Cascade)
  proyecto         Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("inversiones")
}

model EscrowMilestone {
  id          String    @id @default(cuid())
  proyectoId  String
  titulo      String
  descripcion String?
  porcentaje  Float
  estado      String    @default("PENDIENTE")
  fechaLogro  DateTime?
  createdAt   DateTime  @default(now())
  proyecto    Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("hitos_escrow")
}

model Etapa {
  id         String    @id @default(cuid())
  proyectoId String
  nombre     String
  orden      Int
  estado     String    @default("PENDIENTE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  proyecto   Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  manzanas   Manzana[]

  @@index([proyectoId])
  @@map("etapas")
}

model Manzana {
  id          String   @id @default(cuid())
  etapaId     String
  nombre      String
  coordenadas String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  etapa       Etapa    @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  unidades    Unidad[]

  @@index([etapaId])
  @@map("manzanas")
}

model Unidad {
  id                    String            @id @default(cuid())
  manzanaId             String
  numero                String
  tipo                  String            @default("LOTE")
  superficie            Float?
  frente                Float?
  fondo                 Float?
  esEsquina             Boolean           @default(false)
  orientacion           String?
  precio                Float?
  moneda                String            @default("USD")
  geoJSON               String?
  centerLat             Float?
  centerLng             Float?
  financiacion          String?
  estado                String            @default("DISPONIBLE")
  coordenadasMasterplan String?
  imagenes              String?
  tour360Url            String?
  responsableId         String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  historial             HistorialUnidad[]
  oportunidades         Oportunidad[]
  reservas              Reserva[]
  tours                 Tour360[]
  tourHotspots          Hotspot[]
  manzana               Manzana           @relation(fields: [manzanaId], references: [id], onDelete: Cascade)
  responsable           User?             @relation("ResponsableUnidad", fields: [responsableId], references: [id])

  @@index([manzanaId])
  @@index([estado])
  @@index([responsableId])
  @@index([manzanaId, estado])
  @@map("unidades")
}

model Lead {
  id                   String        @id @default(cuid())
  nombre               String
  email                String?
  telefono             String?
  origen               String        @default("WEB")
  proyectoId           String?
  unidadInteres        String?
  estado               String        @default("NUEVO")
  asignadoAId          String?
  ultimoContacto       DateTime?
  fuente               String?
  campana              String?
  mensaje              String?
  notas                String?
  aiQualificationScore Int?
  lastAiSummary        String?
  automationStatus     String        @default("MANUAL")
  communityType        String        @default("NONE")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  mensajes             LeadMessage[]
  asignadoA            User?         @relation("LeadAsignado", fields: [asignadoAId], references: [id])
  proyecto             Proyecto?     @relation(fields: [proyectoId], references: [id])
  oportunidades        Oportunidad[]
  reservas             Reserva[]
  tareas               Tarea[]

  @@index([email])
  @@index([telefono])
  @@index([proyectoId])
  @@index([asignadoAId])
  @@index([estado])
  @@index([asignadoAId, estado])
  @@map("leads")
}

model LeadMessage {
  id        String   @id @default(cuid())
  leadId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_messages")
}

model Oportunidad {
  id                  String    @id @default(cuid())
  leadId              String
  proyectoId          String
  unidadId            String?
  etapa               String    @default("NUEVO")
  probabilidad        Int       @default(0)
  valorEstimado       Decimal?  @db.Decimal(18, 2)
  presupuesto         Decimal?  @db.Decimal(18, 2)
  fechaCierreEstimada DateTime?
  proximaAccion       String?
  fechaProximaAccion  DateTime?
  motivoPerdida       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  proyecto            Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  unidad              Unidad?   @relation(fields: [unidadId], references: [id])

  @@map("oportunidades")
}

model Tarea {
  id               String    @id @default(cuid())
  titulo           String
  descripcion      String?
  fechaVencimiento DateTime
  prioridad        String    @default("MEDIA")
  estado           String    @default("PENDIENTE")
  leadId           String?
  usuarioId        String
  proyectoId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lead             Lead?     @relation(fields: [leadId], references: [id])
  proyecto         Proyecto? @relation(fields: [proyectoId], references: [id])
  usuario          User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tareas")
}

model Reserva {
  id                String   @id @default(cuid())
  unidadId          String
  leadId            String
  vendedorId        String
  fechaInicio       DateTime @default(now())
  fechaVencimiento  DateTime
  montoSena         Decimal?  @db.Decimal(18, 2)
  estadoPago        String   @default("PENDIENTE")
  documentoGenerado String?
  estado            String   @default("ACTIVA")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unidad            Unidad   @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  vendedor          User     @relation("VendedorReserva", fields: [vendedorId], references: [id], onDelete: Cascade)

  @@index([unidadId])
  @@index([leadId])
  @@index([vendedorId])
  @@index([estado])
  @@index([createdAt])
  @@map("reservas")
}

model HistorialUnidad {
  id             String   @id @default(cuid())
  unidadId       String
  usuarioId      String
  estadoAnterior String
  estadoNuevo    String
  motivo         String?
  createdAt      DateTime @default(now())
  unidad         Unidad   @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  usuario        User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([unidadId, createdAt])
  @@map("historial_unidades")
}

model Tour360 {
  id         String   @id @default(cuid())
  proyectoId String
  unidadId   String?  // Optional: A tour can be global for the project or specific to a unit
  nombre     String
  estado     String   @default("PENDIENTE") // PENDING, APPROVED, REJECTED
  notasAdmin String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  unidad     Unidad?  @relation(fields: [unidadId], references: [id])
  scenes     TourScene[]

  @@map("tours_360")
}

model TourScene {
  id         String   @id @default(cuid())
  tourId     String
  title      String
  imageUrl   String
  isDefault  Boolean  @default(false)
  order      Int      @default(0)
  category   String   @default("RAW") // RAW, RENDERED
  
  tour       Tour360  @relation(fields: [tourId], references: [id], onDelete: Cascade)
  hotspots   Hotspot[]

  @@index([tourId])
  @@map("tour_scenes")
}

model Hotspot {
  id            String    @id @default(cuid())
  sceneId       String
  unidadId      String    // Mandatory for inventory sync
  type          String    @default("INFO") // INFO, SCENE, LINK, UNIT
  pitch         Float
  yaw           Float
  text          String?
  targetSceneId String?   // For SCENE type
  
  scene         TourScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  unidad        Unidad    @relation(fields: [unidadId], references: [id])

  @@index([sceneId])
  @@index([unidadId])
  @@map("tour_hotspots")
}

model Infraestructura {
  id                 String    @id @default(cuid())
  proyectoId         String
  nombre             String
  categoria          String    // vialidad | areas_verdes | deportivo | edificaciones | servicios | otro
  tipo               String    // subtipo dentro de la categoría
  geometriaTipo      String    // poligono | linea | punto
  coordenadas        String    // JSON: [[lat, lng], ...]
  estado             String    @default("planificado") // planificado | en_proyecto | en_construccion | construido | en_mantenimiento
  descripcion        String?
  superficie         Float?
  longitudM          Float?
  fechaEstimadaFin   DateTime?
  porcentajeAvance   Int       @default(0)
  fotos              String?   // JSON array of URLs
  colorPersonalizado String?
  orden              Int       @default(0)
  visible            Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  proyecto           Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("infraestructuras")
}

model Banner {
  id          String    @id @default(cuid())
  titulo      String
  tipo        String    @default("IMAGEN")
  mediaUrl    String
  linkDestino String?
  posicion    String    @default("HOME_TOP")
  prioridad   Int       @default(0)
  estado      String    @default("PENDIENTE")
  fechaInicio DateTime?
  fechaFin    DateTime?
  notasAdmin  String?
  creadoPorId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  creadoPor   User?     @relation("BannerCreador", fields: [creadoPorId], references: [id])
  pago        Pago?

  @@map("banners")
}

model Testimonio {
  id            String    @id @default(cuid())
  autorNombre   String
  autorTipo     String    @default("USUARIO")
  autorContacto String?
  texto         String
  rating        Int?      @default(5)
  mediaUrl      String?
  proyectoId    String?
  estado        String    @default("PENDIENTE")
  destacado     Boolean   @default(false)
  notasAdmin    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  proyecto      Proyecto? @relation(fields: [proyectoId], references: [id])

  @@map("testimonios")
}

model Documentacion {
  id          String    @id @default(cuid())
  tipo        String
  archivoUrl  String
  estado      String    @default("PENDIENTE")
  comentarios String?
  usuarioId   String?
  proyectoId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  proyecto    Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  usuario     User?     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("documentacion")
}

model Pago {
  id             String    @id @default(cuid())
  monto          Decimal   @db.Decimal(18, 2)
  moneda         String    @default("USD")
  concepto       String?
  estado         String    @default("PENDIENTE")
  tipo           String?   // WALLET_DEPOSIT, WALLET_WITHDRAWAL, PROJECT_ACTIVATION, etc.
  comprobanteUrl String?
  fechaPago      DateTime  @default(now())
  usuarioId      String
  proyectoId     String?
  bannerId       String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  banner         Banner?   @relation(fields: [bannerId], references: [id])
  proyecto       Proyecto? @relation(fields: [proyectoId], references: [id])
  usuario        User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([proyectoId])
  @@map("pagos")
}

model Notificacion {
  id         String   @id @default(cuid())
  usuarioId  String
  tipo       String
  titulo     String
  mensaje    String
  leido      Boolean  @default(false)
  linkAccion String?
  createdAt  DateTime @default(now())
  usuario    User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leido])
  @@index([createdAt])
  @@map("notificaciones")
}

model Noticia {
  id        String   @id @default(cuid())
  titulo    String
  slug      String   @unique
  excerpt   String?
  contenido String
  categoria String   @default("GENERAL")
  imagenUrl String?
  destacada Boolean  @default(false)
  autorId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  autor     User?    @relation("NoticiaAutor", fields: [autorId], references: [id])

  @@map("noticias")
}
