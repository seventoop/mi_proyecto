generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  engineType    = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                       String                    @id @default(cuid())
  nombre                   String
  slug                     String                    @unique
  plan                     String                    @default("FREE")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  planId                   String?
  banners                  Banner[]
  blogPosts                BlogPost[]
  integrationConfigs       IntegrationConfig[]
  leads                    Lead[]
  logicToopFlows           LogicToopFlow[]
  logicToopRecommendations LogicToopRecommendation[]
  planRef                  Plan?                     @relation(fields: [planId], references: [id])
  pipelineEtapas           PipelineEtapa[]
  proyectoUsuarios         ProyectoUsuario[]
  proyectos                Proyecto[]
  users                    User[]
  workflows                Workflow[]

  @@index([planId])
  @@map("organizations")
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  password              String?
  nombre                String
  rol                   String                @default("CLIENTE")
  whatsappNumber        String?
  aiAgentTone           String                @default("PROFESIONAL")
  useAiCopilot          Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  apellido              String?
  telefono              String?
  direccion             String?
  apodo                 String?
  avatar                String?
  bio                   String?
  fechaNacimiento       DateTime?
  kycStatus             String                @default("PENDIENTE")
  configuracion         String?
  saldo                 Decimal               @default(0) @db.Decimal(18, 2)
  demoEndsAt            DateTime?
  demoUsed              Boolean               @default(false)
  riskLevel             String                @default("low")
  riskReason            String?
  orgId                 String?
  kycRequiredAt         DateTime?
  kycSubmittedAt        DateTime?
  developerVerified     Boolean               @default(false)
  passwordResetExpires  DateTime?
  passwordResetToken    String?               @unique
  googleId              String?               @unique
  auditLogs             AuditLog[]
  bannersAprobados      Banner[]              @relation("BannerAprobador")
  bannersCreados        Banner[]              @relation("BannerCreador")
  blogPosts             BlogPost[]            @relation("BlogPostAutor")
  documentacion         Documentacion[]
  favoritos             FavoritoProyecto[]
  historialAcciones     HistorialUnidad[]
  inversiones           Inversion[]           @relation("InversorInversion")
  kycProfile            KycProfile?
  leadMessages          LeadMessage[]
  leadsAsignados        Lead[]                @relation("LeadAsignado")
  noticiasEscritas      Noticia[]             @relation("NoticiaAutor")
  notificaciones        Notificacion[]
  pagos                 Pago[]
  historialPrecios      PriceHistory[]
  estadoLogsRealizados  ProyectoEstadoLog[]
  mandatosAprobados     ProyectoUsuario[]     @relation("AprobadorMandato")
  relacionesCreadas     ProyectoUsuario[]     @relation("AsignadorRelacion")
  roleChangeRequests    RoleChangeRequest[]
  proyectosRelaciones   ProyectoUsuario[]
  proyectosCreados      Proyecto[]            @relation("ProyectoCreador")
  reservasComoComprador Reserva[]             @relation("ReservasComprador")
  reservasVendedor      Reserva[]             @relation("VendedorReserva")
  tareas                Tarea[]
  unidadesResponsable   Unidad[]              @relation("ResponsableUnidad")
  aiTasksRequested      LogicToopAiTask[]     @relation("AiTaskRequester")
  aiTasksApproved       LogicToopAiApproval[] @relation("AiTaskApprover")
  organization          Organization?         @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("users")
}

model RoleChangeRequest {
  id            String   @id @default(cuid())
  userId        String
  currentRole   String
  requestedRole String
  status        String   @default("PENDIENTE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([requestedRole, status])
  @@map("role_change_requests")
}

model KycProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  selfieUrl              String?
  nombrePublico          String?
  tipoDeveloper          String?
  yearsExperience        Int?
  proyectosRealizados    Int?
  descripcionProfesional String?
  especialidad           String?
  razonSocial            String?
  nombreComercial        String?
  cuitEmpresa            String?
  direccionOficina       String?
  ciudad                 String?
  provincia              String?
  pais                   String?   @default("Argentina")
  telefonoComercial      String?
  sitioWeb               String?
  linkedinEmpresa        String?
  estatutoUrl            String?
  matriculaUrl           String?
  constanciaBancariaUrl  String?
  estado                 String    @default("PENDIENTE")
  notasAdmin             String?
  verificadoPorId        String?
  verificadoAt           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  dniDorso               String?
  dniFrente              String?
  ingresosEstimados      String?
  pasaporteUrl           String?
  patrimonioEstimado     String?
  perfilRiesgo           String?
  politicasAceptadas     Boolean   @default(false)
  politicasAceptadasAt   DateTime?
  tipo                   String    @default("DESARROLLADOR")
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_profiles")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

model Proyecto {
  id                   String                   @id @default(cuid())
  nombre               String
  slug                 String?                  @unique
  descripcion          String?
  ubicacion            String?
  estado               String                   @default("PLANIFICACION")
  tipo                 String                   @default("URBANIZACION")
  imagenPortada        String?
  galeria              String?
  documentos           String?
  masterplanSVG        String?
  mapCenterLat         Float?                   @default(-34.6037)
  mapCenterLng         Float?                   @default(-58.3816)
  mapZoom              Int?                     @default(16)
  overlayUrl           String?
  overlayBounds        String?
  overlayRotation      Float?                   @default(0)
  invertible           Boolean                  @default(false)
  precioM2Inversor     Decimal?                 @db.Decimal(18, 2)
  precioM2Mercado      Decimal?                 @db.Decimal(18, 2)
  metaM2Objetivo       Decimal?                 @db.Decimal(18, 2)
  m2VendidosInversores Decimal                  @default(0) @db.Decimal(18, 2)
  fechaLimiteFondeo    DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  documentacionEstado  String                   @default("PENDIENTE")
  creadoPorId          String?
  aiKnowledgeBase      String?
  aiSystemPrompt       String?
  demoExpiresAt        DateTime?
  isDemo               Boolean                  @default(false)
  requireKyc           Boolean                  @default(true)
  visibilityStatus     String                   @default("PUBLICADO")
  orgId                String?
  deletedAt            DateTime?
  tour360Url           String?
  estadoValidacion     EstadoValidacionProyecto @default(BORRADOR)
  flagsOverrideAt      DateTime?
  flagsOverridePorId   String?
  puedeCaptarLeads     Boolean                  @default(false)
  puedePublicarse      Boolean                  @default(false)
  puedeReservarse      Boolean                  @default(false)
  planGallery          String?
  banners              Banner[]
  documentacion        Documentacion[]
  etapas               Etapa[]
  favoritos            FavoritoProyecto[]
  hitosEscrow          EscrowMilestone[]
  imagenesMapa         ImagenMapa[]
  infraestructuras     Infraestructura[]
  inversiones          Inversion[]
  leads                Lead[]
  oportunidades        Oportunidad[]
  pagos                Pago[]
  historialPrecios     PriceHistory[]
  featureFlags         ProjectFeatureFlags?
  proyecto_archivos    proyecto_archivos[]
  estadoLogs           ProyectoEstadoLog[]
  imagenes             ProyectoImagen[]
  usuariosRelaciones   ProyectoUsuario[]
  creadoPor            User?                    @relation("ProyectoCreador", fields: [creadoPorId], references: [id])
  organization         Organization?            @relation(fields: [orgId], references: [id])
  tareas               Tarea[]
  testimonios          Testimonio[]
  tours                Tour360[]

  @@index([estado])
  @@index([estadoValidacion])
  @@index([createdAt])
  @@index([visibilityStatus])
  @@index([isDemo])
  @@index([tipo])
  @@index([orgId])
  @@map("proyectos")
}

model ProyectoImagen {
  id                String   @id @default(cuid())
  proyectoId        String
  url               String
  categoria         String
  esPrincipal       Boolean  @default(false)
  masterplanOverlay Json?
  orden             Int      @default(0)
  createdAt         DateTime @default(now())
  proyecto          Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@index([orden])
  @@map("proyecto_imagenes")
}

model Inversion {
  id               String   @id @default(cuid())
  proyectoId       String
  inversorId       String
  m2Comprados      Decimal  @db.Decimal(18, 2)
  montoTotal       Decimal  @db.Decimal(18, 2)
  precioM2Aplicado Decimal  @db.Decimal(18, 2)
  estado           String   @default("ESCROW")
  hashTransaccion  String?
  fechaInversion   DateTime @default(now())
  updatedAt        DateTime @updatedAt
  inversor         User     @relation("InversorInversion", fields: [inversorId], references: [id], onDelete: Cascade)
  proyecto         Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("inversiones")
}

model FavoritoProyecto {
  id         String   @id @default(cuid())
  userId     String
  proyectoId String
  createdAt  DateTime @default(now())
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, proyectoId])
  @@map("favoritos_proyecto")
}

model EscrowMilestone {
  id          String    @id @default(cuid())
  proyectoId  String
  titulo      String
  descripcion String?
  porcentaje  Float
  estado      String    @default("PENDIENTE")
  fechaLogro  DateTime?
  createdAt   DateTime  @default(now())
  proyecto    Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("hitos_escrow")
}

model Etapa {
  id         String    @id @default(cuid())
  proyectoId String
  nombre     String
  orden      Int
  estado     String    @default("PENDIENTE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  proyecto   Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  manzanas   Manzana[]

  @@index([proyectoId])
  @@map("etapas")
}

model Manzana {
  id          String   @id @default(cuid())
  etapaId     String
  nombre      String
  coordenadas String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  etapa       Etapa    @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  unidades    Unidad[]

  @@index([etapaId])
  @@map("manzanas")
}

model PriceHistory {
  id             String   @id @default(cuid())
  proyectoId     String
  usuarioId      String
  precioAnterior Decimal  @db.Decimal(18, 2)
  precioNuevo    Decimal  @db.Decimal(18, 2)
  tipo           String
  motivo         String?
  createdAt      DateTime @default(now())
  proyecto       Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  usuario        User     @relation(fields: [usuarioId], references: [id])

  @@index([proyectoId])
  @@index([createdAt])
  @@map("price_history")
}

model Unidad {
  id                    String            @id @default(cuid())
  manzanaId             String
  numero                String
  tipo                  String            @default("LOTE")
  superficie            Float?
  frente                Float?
  fondo                 Float?
  esEsquina             Boolean           @default(false)
  orientacion           String?
  precio                Float?
  moneda                String            @default("USD")
  geoJSON               String?
  centerLat             Float?
  centerLng             Float?
  financiacion          String?
  estado                String            @default("DISPONIBLE")
  coordenadasMasterplan String?
  imagenes              String?
  tour360Url            String?
  responsableId         String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  polygon               Json?
  bloqueadoHasta        DateTime?
  historial             HistorialUnidad[]
  imagenesMapa          ImagenMapa[]
  oportunidades         Oportunidad[]
  reservas              Reserva[]
  tourHotspots          Hotspot[]
  tours                 Tour360[]
  manzana               Manzana           @relation(fields: [manzanaId], references: [id], onDelete: Cascade)
  responsable           User?             @relation("ResponsableUnidad", fields: [responsableId], references: [id])

  @@index([manzanaId])
  @@index([estado])
  @@index([responsableId])
  @@index([manzanaId, estado])
  @@map("unidades")
}

model Lead {
  id                   String         @id @default(cuid())
  nombre               String
  email                String?
  telefono             String?
  origen               String         @default("WEB")
  proyectoId           String?
  unidadInteres        String?
  estado               String         @default("NUEVO")
  asignadoAId          String?
  ultimoContacto       DateTime?
  fuente               String?
  campana              String?
  mensaje              String?
  notas                String?
  aiQualificationScore Int?
  lastAiSummary        String?
  automationStatus     String         @default("MANUAL")
  communityType        String         @default("NONE")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  presupuesto          Decimal?       @db.Decimal(18, 2)
  perfilInversor       String?        @default("MODERADO")
  adId                 String?
  adSetId              String?
  campanaId            String?
  canalOrigen          String         @default("WEB")
  orgId                String?
  score                Int?           @default(0)
  etapaId              String?
  mensajes             LeadMessage[]
  asignadoA            User?          @relation("LeadAsignado", fields: [asignadoAId], references: [id])
  etapa                PipelineEtapa? @relation(fields: [etapaId], references: [id])
  organization         Organization?  @relation(fields: [orgId], references: [id])
  proyecto             Proyecto?      @relation(fields: [proyectoId], references: [id])
  oportunidades        Oportunidad[]
  reservas             Reserva[]
  tareas               Tarea[]

  @@index([email])
  @@index([telefono])
  @@index([proyectoId])
  @@index([asignadoAId])
  @@index([estado])
  @@index([orgId])
  @@index([canalOrigen])
  @@index([asignadoAId, estado])
  @@map("leads")
}

model PipelineEtapa {
  id        String       @id @default(cuid())
  orgId     String
  nombre    String
  color     String       @default("#6366f1")
  orden     Int
  esDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  leads     Lead[]
  org       Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("pipeline_etapas")
}

model LeadMessage {
  id        String   @id @default(cuid())
  leadId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  userId    String?
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@map("lead_messages")
}

model Oportunidad {
  id                  String    @id @default(cuid())
  leadId              String
  proyectoId          String
  unidadId            String?
  etapa               String    @default("NUEVO")
  probabilidad        Int       @default(0)
  valorEstimado       Decimal?  @db.Decimal(18, 2)
  presupuesto         Decimal?  @db.Decimal(18, 2)
  fechaCierreEstimada DateTime?
  proximaAccion       String?
  fechaProximaAccion  DateTime?
  motivoPerdida       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lead                Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  proyecto            Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  unidad              Unidad?   @relation(fields: [unidadId], references: [id])

  @@map("oportunidades")
}

model Tarea {
  id               String    @id @default(cuid())
  titulo           String
  descripcion      String?
  fechaVencimiento DateTime
  prioridad        String    @default("MEDIA")
  estado           String    @default("PENDIENTE")
  leadId           String?
  usuarioId        String
  proyectoId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lead             Lead?     @relation(fields: [leadId], references: [id])
  proyecto         Proyecto? @relation(fields: [proyectoId], references: [id])
  usuario          User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tareas")
}

model Reserva {
  id                String   @id @default(cuid())
  unidadId          String
  leadId            String?
  vendedorId        String
  fechaInicio       DateTime @default(now())
  fechaVencimiento  DateTime
  montoSena         Decimal? @db.Decimal(18, 2)
  estadoPago        String   @default("PENDIENTE")
  documentoGenerado String?
  estado            String   @default("ACTIVA")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  compradorEmail    String?
  compradorId       String?
  compradorNombre   String?
  notas             String?
  idempotencyKey    String?  @unique
  comprador         User?    @relation("ReservasComprador", fields: [compradorId], references: [id])
  lead              Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unidad            Unidad   @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  vendedor          User     @relation("VendedorReserva", fields: [vendedorId], references: [id], onDelete: Cascade)

  @@index([unidadId])
  @@index([leadId])
  @@index([compradorId])
  @@index([vendedorId])
  @@index([estado])
  @@index([createdAt])
  @@map("reservas")
}

model HistorialUnidad {
  id             String   @id @default(cuid())
  unidadId       String
  usuarioId      String
  estadoAnterior String
  estadoNuevo    String
  motivo         String?
  createdAt      DateTime @default(now())
  unidad         Unidad   @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  usuario        User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([unidadId, createdAt])
  @@map("historial_unidades")
}

model Tour360 {
  id          String      @id @default(cuid())
  proyectoId  String
  unidadId    String?
  nombre      String
  estado      String      @default("PENDIENTE")
  isPublished Boolean     @default(false)
  notasAdmin  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  anchors     Json?
  scenes      TourScene[]
  proyecto    Proyecto    @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  unidad      Unidad?     @relation(fields: [unidadId], references: [id])

  @@map("tours_360")
}

model TourScene {
  id                String    @id @default(cuid())
  tourId            String
  title             String
  imageUrl          String
  isDefault         Boolean   @default(false)
  order             Int       @default(0)
  category          String    @default("RAW")
  pannellumHotspots Json?
  thumbnailUrl      String?
  masterplanOverlay Json?
  hotspots          Hotspot[]
  tour              Tour360   @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@map("tour_scenes")
}

model Hotspot {
  id            String    @id @default(cuid())
  sceneId       String
  unidadId      String?
  type          String    @default("INFO")
  pitch         Float
  yaw           Float
  text          String?
  targetSceneId String?
  scene         TourScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  unidad        Unidad?   @relation(fields: [unidadId], references: [id])

  @@index([sceneId])
  @@index([unidadId])
  @@map("tour_hotspots")
}

model Banner {
  id           String        @id @default(cuid())
  titulo       String
  tipo         String        @default("IMAGEN")
  mediaUrl     String
  linkDestino  String?
  posicion     String        @default("HOME_TOP")
  prioridad    Int           @default(0)
  estado       String        @default("DRAFT")
  fechaInicio  DateTime?
  fechaFin     DateTime?
  notasAdmin   String?
  creadoPorId  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  approvedAt   DateTime?
  approvedById String?
  context      String        @default("ORG_LANDING")
  ctaText      String?
  ctaUrl       String?
  headline     String?
  internalName String?
  orgId        String?
  projectId    String?
  publishedAt  DateTime?
  subheadline  String?
  tagline      String?
  approvedBy   User?         @relation("BannerAprobador", fields: [approvedById], references: [id])
  creadoPor    User?         @relation("BannerCreador", fields: [creadoPorId], references: [id])
  organization Organization? @relation(fields: [orgId], references: [id])
  proyecto     Proyecto?     @relation(fields: [projectId], references: [id])
  pago         Pago?

  @@index([orgId])
  @@index([context, orgId, estado])
  @@map("banners")
}

model Testimonio {
  id            String    @id @default(cuid())
  autorNombre   String
  autorTipo     String    @default("USUARIO")
  autorContacto String?
  texto         String
  rating        Int?      @default(5)
  mediaUrl      String?
  proyectoId    String?
  estado        String    @default("PENDIENTE")
  destacado     Boolean   @default(false)
  notasAdmin    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  proyecto      Proyecto? @relation(fields: [proyectoId], references: [id])

  @@map("testimonios")
}

model Documentacion {
  id          String    @id @default(cuid())
  tipo        String
  archivoUrl  String
  estado      String    @default("PENDIENTE")
  comentarios String?
  usuarioId   String?
  proyectoId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  proyecto    Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  usuario     User?     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("documentacion")
}

model Pago {
  id             String    @id @default(cuid())
  monto          Decimal   @db.Decimal(18, 2)
  moneda         String    @default("USD")
  concepto       String?
  estado         String    @default("PENDIENTE")
  comprobanteUrl String?
  fechaPago      DateTime  @default(now())
  usuarioId      String
  proyectoId     String?
  bannerId       String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tipo           String?
  idempotencyKey String?   @unique
  banner         Banner?   @relation(fields: [bannerId], references: [id])
  proyecto       Proyecto? @relation(fields: [proyectoId], references: [id])
  usuario        User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([proyectoId])
  @@map("pagos")
}

model Notificacion {
  id         String   @id @default(cuid())
  usuarioId  String
  tipo       String
  titulo     String
  mensaje    String
  leido      Boolean  @default(false)
  linkAccion String?
  createdAt  DateTime @default(now())
  usuario    User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, leido])
  @@index([createdAt])
  @@map("notificaciones")
}

model BlogPost {
  id        String        @id @default(cuid())
  titulo    String
  contenido String
  slug      String        @unique
  status    String        @default("PENDIENTE")
  autorId   String
  orgId     String?
  imagen    String?
  tags      String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  autor     User          @relation("BlogPostAutor", fields: [autorId], references: [id])
  org       Organization? @relation(fields: [orgId], references: [id])

  @@map("blog_posts")
}

model Noticia {
  id        String   @id @default(cuid())
  titulo    String
  slug      String   @unique
  excerpt   String?
  contenido String
  categoria String   @default("GENERAL")
  imagenUrl String?
  destacada Boolean  @default(false)
  autorId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  autor     User?    @relation("NoticiaAutor", fields: [autorId], references: [id])

  @@map("noticias")
}

model Workflow {
  id          String         @id @default(cuid())
  orgId       String
  nombre      String
  descripcion String?
  trigger     String
  activo      Boolean        @default(false)
  version     Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  nodos       WorkflowNodo[]
  runs        WorkflowRun[]
  org         Organization   @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("workflows")
}

model WorkflowNodo {
  id         String   @id @default(cuid())
  workflowId String
  tipo       String
  orden      Int
  config     Json
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_nodos")
}

model WorkflowRun {
  id         String            @id @default(cuid())
  workflowId String
  trigger    String
  entityId   String?
  estado     String            @default("RUNNING")
  startedAt  DateTime          @default(now())
  finishedAt DateTime?
  error      String?
  pasos      WorkflowRunPaso[]
  workflow   Workflow          @relation(fields: [workflowId], references: [id])

  @@index([workflowId])
  @@index([entityId])
  @@map("workflow_runs")
}

model WorkflowRunPaso {
  id        String      @id @default(cuid())
  runId     String
  nodoTipo  String
  input     Json?
  output    Json?
  estado    String      @default("OK")
  ms        Int?
  createdAt DateTime    @default(now())
  run       WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("workflow_run_pasos")
}

model Plan {
  id        String         @id @default(cuid())
  nombre    String
  precio    Float          @default(0)
  limites   Json
  features  Json
  createdAt DateTime       @default(now())
  orgs      Organization[]

  @@map("plans")
}

model ProjectFeatureFlags {
  id          String   @id @default(cuid())
  projectId   String   @unique
  infoGeneral Boolean  @default(true)
  archivos    Boolean  @default(false)
  documentos  Boolean  @default(false)
  pagos       Boolean  @default(false)
  masterplan  Boolean  @default(false)
  motorPlanos Boolean  @default(false)
  tour360     Boolean  @default(false)
  etapas      Boolean  @default(false)
  inventario  Boolean  @default(false)
  metricas    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  proyecto    Proyecto @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_feature_flags")
}

model proyecto_archivos {
  id                  String   @id
  proyectoId          String
  tipo                String
  nombre              String
  url                 String
  visiblePublicamente Boolean  @default(false)
  createdAt           DateTime @default(now())
  proyectos           Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
}

model LogicToopFlow {
  id                      String                    @id @default(cuid())
  orgId                   String
  nombre                  String
  descripcion             String?
  triggerType             String
  actions                 Json
  activo                  Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  metadata                Json?                     @default("{}")
  recommendationId        String?
  status                  LogicToopFlowStatus       @default(DRAFT)
  executions              LogicToopExecution[]
  org                     Organization              @relation(fields: [orgId], references: [id])
  recommendation          LogicToopRecommendation?  @relation(fields: [recommendationId], references: [id])
  optimizationSuggestions LogicToopRecommendation[] @relation("FlowOptimization")

  @@index([orgId])
  @@index([triggerType])
  @@index([status])
  @@index([recommendationId])
  @@map("logic_toop_flows")
}

model LogicToopExecution {
  id               String            @id @default(cuid())
  flowId           String
  triggerPayload   Json
  status           String            @default("RUNNING")
  logs             Json
  startedAt        DateTime          @default(now())
  finishedAt       DateTime?
  resumeAt         DateTime?
  currentStepIndex Int               @default(0)
  aiEstimatedCost  Float             @default(0)
  aiModelsUsed     Json?
  aiTokensUsed     Int               @default(0)
  errorMessage     String?
  flow             LogicToopFlow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  jobs             LogicToopJob[]
  aiTasks          LogicToopAiTask[]

  @@index([flowId])
  @@index([status, resumeAt])
  @@index([startedAt])
  @@map("logic_toop_executions")
}

model LogicToopJob {
  id          String             @id @default(cuid())
  executionId String
  orgId       String
  actionType  String
  config      Json
  payload     Json
  attempts    Int                @default(0)
  maxRetries  Int                @default(0)
  status      String             @default("PENDING")
  scheduledAt DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  execution   LogicToopExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([executionId])
  @@index([orgId])
  @@map("logic_toop_jobs")
}

model LogicToopTemplate {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  triggerType String
  createdAt   DateTime @default(now())
  category    String   @default(" Lead Automation")
  createdBy   String?
  flowConfig  Json
  updatedAt   DateTime @updatedAt
  version     Int      @default(1)

  @@map("logic_toop_templates")
}

model LogicToopRecommendation {
  id               String          @id @default(cuid())
  orgId            String
  type             String
  title            String
  description      String
  problemDetected  String?
  proposedSolution String?
  expectedImpact   String?
  confidence       Float           @default(0)
  severity         String          @default("INFO")
  status           String          @default("NEW")
  suggestedTrigger String?
  suggestedNodes   Json?
  signals          Json?           @default("{}")
  sourceMetrics    Json?           @default("{}")
  explanation      Json?           @default("{}")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  sourceFlowId     String?
  generatedFlows   LogicToopFlow[]
  org              Organization    @relation(fields: [orgId], references: [id])
  sourceFlow       LogicToopFlow?  @relation("FlowOptimization", fields: [sourceFlowId], references: [id])

  @@index([orgId])
  @@index([status])
  @@index([type])
  @@map("logic_toop_recommendations")
}

model IntegrationConfig {
  id        String       @id @default(cuid())
  orgId     String
  provider  String
  status    String       @default("INACTIVE")
  config    Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@index([orgId])
  @@index([provider])
  @@map("integration_configs")
}

model LeadIntake {
  id         String   @id @default(cuid())
  source     String
  rawPayload Json
  status     String   @default("PENDING")
  error      String?
  orgId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([source])
  @@map("lead_intake")
}

model ImagenMapa {
  id           String   @id @default(cuid())
  proyectoId   String
  unidadId     String?
  url          String
  tipo         String   @default("foto")
  titulo       String?
  lat          Float
  lng          Float
  orden        Int      @default(0)
  altitudM     Float?   @default(500)
  imageHeading Float?   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  latOffset    Float?   @default(0)
  lngOffset    Float?   @default(0)
  planRotation Float?   @default(0)
  planScale    Float?   @default(1)
  proyecto     Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  unidad       Unidad?  @relation(fields: [unidadId], references: [id])

  @@index([proyectoId])
  @@index([unidadId])
  @@map("imagenes_mapa")
}

model Infraestructura {
  id                 String    @id @default(cuid())
  proyectoId         String
  nombre             String
  categoria          String
  tipo               String
  geometriaTipo      String
  coordenadas        String
  estado             String    @default("planificado")
  descripcion        String?
  superficie         Float?
  longitudM          Float?
  fechaEstimadaFin   DateTime?
  porcentajeAvance   Int       @default(0)
  fotos              String?
  colorPersonalizado String?
  orden              Int       @default(0)
  visible            Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  proyecto           Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("infraestructuras")
}

model ProyectoUsuario {
  id                         String                 @id @default(cuid())
  proyectoId                 String
  userId                     String
  orgId                      String
  tipoRelacion               TipoRelacionProyecto
  estadoRelacion             EstadoRelacionProyecto @default(PENDIENTE)
  permisoEditarProyecto      Boolean                @default(false)
  permisoSubirDocumentacion  Boolean                @default(false)
  permisoVerLeadsGlobales    Boolean                @default(false)
  permisoVerMetricasGlobales Boolean                @default(false)
  tipoMandato                TipoMandato?
  documentoMandatoUrl        String?
  mandatoVigenciaDesde       DateTime?
  mandatoVigenciaHasta       DateTime?
  confirmadoPorEmpresa       Boolean                @default(false)
  fechaConfirmacion          DateTime?
  aprobadoPorAdminId         String?
  asignadoPorId              String?
  notas                      String?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  aprobadoPor                User?                  @relation("AprobadorMandato", fields: [aprobadoPorAdminId], references: [id])
  asignadoPor                User?                  @relation("AsignadorRelacion", fields: [asignadoPorId], references: [id])
  org                        Organization           @relation(fields: [orgId], references: [id])
  proyecto                   Proyecto               @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  user                       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proyectoId, userId])
  @@index([proyectoId])
  @@index([userId])
  @@index([orgId])
  @@index([tipoRelacion, estadoRelacion])
  @@map("proyecto_usuarios")
}

model ProyectoEstadoLog {
  id             String                   @id @default(cuid())
  proyectoId     String
  estadoAnterior EstadoValidacionProyecto
  estadoNuevo    EstadoValidacionProyecto
  realizadoPorId String
  motivo         String?
  flagsSnapshot  Json
  createdAt      DateTime                 @default(now())
  proyecto       Proyecto                 @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  realizadoPor   User                     @relation(fields: [realizadoPorId], references: [id])

  @@index([proyectoId, createdAt])
  @@map("proyecto_estado_logs")
}

enum TipoRelacionProyecto {
  OWNER
  VENDEDOR_ASIGNADO
  COMERCIALIZADOR_EXCLUSIVO
  COMERCIALIZADOR_NO_EXCLUSIVO
  COLABORADOR
  SOLO_LECTURA
}

enum EstadoRelacionProyecto {
  ACTIVA
  PENDIENTE
  RECHAZADA
  VENCIDA
}

enum EstadoValidacionProyecto {
  BORRADOR
  PENDIENTE_VALIDACION
  EN_REVISION
  APROBADO
  OBSERVADO
  RECHAZADO
  SUSPENDIDO
}

enum TipoMandato {
  EXCLUSIVO
  NO_EXCLUSIVO
}

enum LogicToopFlowStatus {
  DRAFT
  TESTING
  ACTIVE
  PAUSED
  ARCHIVED
}

model LogicToopAiAgent {
  id           String            @id @default(cuid())
  orgId        String
  name         String
  role         String
  systemPrompt String?
  tools        Json              @default("[]")
  status       String            @default("ACTIVE")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tasks        LogicToopAiTask[]

  @@index([orgId])
  @@index([status])
  @@map("logictoop_ai_agents")
}

model LogicToopAiTask {
  id             String                @id @default(cuid())
  orgId          String
  executionId    String?
  agentId        String
  requestedById  String
  inputPayload   Json
  outputResult   Json?
  status         String                @default("PENDING")
  costTokens     Int                   @default(0)
  costEstimated  Float                 @default(0)
  paperclipRunId String?
  errorLogs      Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  agent          LogicToopAiAgent      @relation(fields: [agentId], references: [id])
  execution      LogicToopExecution?   @relation(fields: [executionId], references: [id])
  requestedBy    User                  @relation("AiTaskRequester", fields: [requestedById], references: [id])
  approvals      LogicToopAiApproval[]

  @@index([orgId])
  @@index([executionId])
  @@index([agentId])
  @@index([requestedById])
  @@index([status])
  @@map("logictoop_ai_tasks")
}

model LogicToopAiApproval {
  id           String          @id @default(cuid())
  taskId       String
  approvedById String
  approvedAt   DateTime?
  comments     String?
  actionTaken  String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  task         LogicToopAiTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  approvedBy   User            @relation("AiTaskApprover", fields: [approvedById], references: [id])

  @@index([taskId])
  @@index([approvedById])
  @@map("logictoop_ai_approvals")
}
