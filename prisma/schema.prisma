// Prisma Schema - Plataforma Inmobiliaria GentionGeodevia
// Generado para PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS (Removed for SQLite compatibility - handled as Strings in app)
// ─────────────────────────────────────────────


// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  nombre    String
  rol       String      @default("VENDEDOR")
  whatsappNumber  String?
  aiAgentTone     String   @default("PROFESIONAL")
  useAiCopilot    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile Fields
  apellido        String?
  telefono        String?
  direccion       String?
  apodo           String?
  avatar          String?
  bio             String?
  fechaNacimiento DateTime?

  // Relaciones
  unidadesResponsable Unidad[]       @relation("ResponsableUnidad")
  leadsAsignados      Lead[]         @relation("LeadAsignado")
  reservasVendedor    Reserva[]      @relation("VendedorReserva")
  inversiones         Inversion[]    @relation("InversorInversion")
  historialAcciones   HistorialUnidad[]
  tareas             Tarea[]
  
  // Nuevas relaciones Admin
  bannersCreados     Banner[]       @relation("BannerCreador")
  notificaciones     Notificacion[]
  pagos              Pago[]
  documentacion      Documentacion[] // KYC docs
  kycStatus          String         @default("PENDIENTE") // PENDIENTE, EN_REVISION, VERIFICADO, RECHAZADO
  configuracion      String?        // JSON: { notifications: { kyc: true, ... }, theme: "system" }
  proyectosCreados   Proyecto[]     @relation("ProyectoCreador")
  noticiasEscritas   Noticia[]      @relation("NoticiaAutor")
  saldo              Float          @default(0)
  riskLevel          String         @default("low") // low, medium, high
  riskReason         String?

  // Demo Mode
  demoEndsAt         DateTime?      // Fin del período demo de 48h
  demoUsed           Boolean        @default(false)

  @@map("users")
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

model Proyecto {
  id               String          @id @default(cuid())
  nombre           String
  slug             String?         @unique
  descripcion      String?
  ubicacion        String?
  estado           String  @default("PLANIFICACION")
  tipo             String    @default("URBANIZACION")
  imagenPortada    String?
  galeria          String?        // JSON array de URLs
  documentos       String?        // JSON array de URLs
  masterplanSVG    String?
  // Configuración del Mapa Interactivo (Overlay)
  mapCenterLat    Float?   @default(-34.6037)
  mapCenterLng    Float?   @default(-58.3816)
  mapZoom         Int?     @default(16)
  
  // Configuración de la Imagen Overlay
  overlayUrl      String?  // URL de la imagen del masterplan
  overlayBounds   String?  // JSON: [[lat1,lng1], [lat2,lng2]] (Esquinas)
  overlayRotation Float?   @default(0) // Rotación en grados
  
  // Campos de Inversión / Escrow
  invertible           Boolean   @default(false)
  precioM2Inversor     Float?    // Precio costo (wholesale)
  precioM2Mercado      Float?    // Precio lanzamiento proyectado
  metaM2Objetivo       Float?    // Cuántos m2 se necesitan fondear
  m2VendidosInversores Float     @default(0)
  fechaLimiteFondeo    DateTime?
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relaciones
  etapas        Etapa[]
  leads         Lead[]
  oportunidades Oportunidad[]
  tours         Tour360[]
  tareas        Tarea[]
  inversiones   Inversion[]
  hitosEscrow   EscrowMilestone[]
  
  // Nuevas relaciones Admin
  documentacion Documentacion[] // Planos, aprobaciones municipales
  pagos         Pago[]
  testimonios   Testimonio[]
  
  documentacionEstado String @default("PENDIENTE") // PENDIENTE, EN_REVISION, APROBADO, RECHAZADO

  creadoPorId   String?
  creadoPor     User?    @relation("ProyectoCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)

  // Demo Mode
  isDemo             Boolean        @default(false)
  demoExpiresAt      DateTime?
  visibilityStatus   String         @default("PUBLICADO") // PUBLICADO, DESPUBLICADO, SUSPENDIDO
  requireKyc         Boolean        @default(true)

  // AI Agent Fields
  aiKnowledgeBase String?  @db.Text
  aiSystemPrompt  String?  @db.Text

  // Masterplan / Technical Files
  archivosTecnicos ProyectoArchivo[]
  imagenes         ProyectoImagen[]

  @@map("proyectos")
  @@index([estado])
  @@index([createdAt])
}

model ProyectoArchivo {
  id                 String   @id @default(cuid())
  proyectoId         String
  tipo               String   // PLANO, MEMORIA, LEGAL, RENDER, OTRO
  nombre             String
  url                String
  visiblePublicamente Boolean  @default(false)
  createdAt          DateTime @default(now())

  // Relaciones
  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("proyecto_archivos")
  @@index([proyectoId])
}

model ProyectoImagen {
  id         String   @id @default(cuid())
  proyectoId String
  url        String
  categoria  String   // RENDER, AVANCE_OBRA, MASTERPLAN, INTERIOR, EXTERIOR
  esPrincipal Boolean  @default(false)
  orden      Int      @default(0)
  createdAt  DateTime @default(now())

  // Relaciones
  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("proyecto_imagenes")
  @@index([proyectoId])
  @@index([orden])
}

model Inversion {
  id              String   @id @default(cuid())
  proyectoId      String
  inversorId      String
  m2Comprados     Float
  montoTotal      Float
  precioM2Aplicado Float
  estado          String   @default("ESCROW") // PENDING, ESCROW, RELEASED, REFUNDED
  hashTransaccion String?
  fechaInversion  DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  inversor User     @relation("InversorInversion", fields: [inversorId], references: [id], onDelete: Cascade)

  @@map("inversiones")
}

model EscrowMilestone {
  id           String   @id @default(cuid())
  proyectoId   String
  titulo       String
  descripcion  String?
  porcentaje   Float    // Porcentaje de fondos a liberar (0-100)
  estado       String   @default("PENDIENTE") // PENDIENTE, COMPLETADO
  fechaLogro   DateTime?
  createdAt    DateTime @default(now())

  // Relaciones
  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("hitos_escrow")
}


model Etapa {
  id         String      @id @default(cuid())
  proyectoId String
  nombre     String
  orden      Int
  estado     String @default("PENDIENTE")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relaciones
  proyecto  Proyecto   @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  manzanas  Manzana[]

  @@map("etapas")
  @@index([proyectoId])
}

model Manzana {
  id          String   @id @default(cuid())
  etapaId     String
  nombre      String
  coordenadas String?    // coordenadas para SVG del masterplan
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  etapa    Etapa    @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  unidades Unidad[]

  @@map("manzanas")
  @@index([etapaId])
}

model Unidad {
  id                    String       @id @default(cuid())
  manzanaId             String
  numero                String
  tipo                  String   @default("LOTE")
  superficie            Float?       // m²
  frente                Float?       // metros
  fondo                 Float?       // metros
  esEsquina             Boolean      @default(false)
  orientacion           String?      // N, S, E, O, NE, NO, SE, SO
  precio                Float?
  moneda                String       @default("USD")
  
  // Georreferenciación
  geoJSON         String?  // Coordenadas del polígono interactivo sobre mapa
  centerLat       Float?
  centerLng       Float?

  financiacion          String?        // { cuotas, anticipo, tasaInteres, ... }
  estado                String @default("DISPONIBLE")
  coordenadasMasterplan String?        // { x, y, width, height, path, ... }
  imagenes              String?     // JSON array de URLs
  tour360Url            String?
  responsableId         String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  // Relaciones
  manzana      Manzana          @relation(fields: [manzanaId], references: [id], onDelete: Cascade)
  responsable  User?            @relation("ResponsableUnidad", fields: [responsableId], references: [id], onDelete: SetNull)
  reservas     Reserva[]
  oportunidades Oportunidad[]
  historial    HistorialUnidad[]
  tours        Tour360[]

  @@map("unidades")
  @@index([manzanaId])
  @@index([estado])
  @@index([responsableId])
  @@index([manzanaId, estado])
}

model Lead {
  id             String      @id @default(cuid())
  nombre         String
  email          String?
  telefono       String?
  origen         String  @default("WEB")
  proyectoId     String?
  unidadInteres  String?    // JSON array de IDs de unidades de interés
  estado         String  @default("NUEVO")
  asignadoAId    String?
  ultimoContacto DateTime?
  fuente         String?    // Facebook, Google, Valla, etc.
  campana        String?
  mensaje        String?
  notas          String?      // JSON array [{ fecha, texto, userId }]
  
  // AI Pilot Fields
  aiQualificationScore Int?
  lastAiSummary        String?   @db.Text
  automationStatus     String    @default("MANUAL") // MANUAL, COPILOT, PILOT
  communityType        String    @default("NONE")   // NONE, OPEN, VIP
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relaciones
  proyecto      Proyecto?     @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  asignadoA     User?         @relation("LeadAsignado", fields: [asignadoAId], references: [id], onDelete: SetNull)
  oportunidades Oportunidad[]
  reservas      Reserva[]
  tareas        Tarea[]
  mensajes      LeadMessage[]

  @@map("leads")
  @@index([email])
  @@index([telefono])
  @@index([proyectoId])
  @@index([asignadoAId])
  @@index([estado])
  @@index([asignadoAId, estado])
}

model LeadMessage {
  id        String   @id @default(cuid())
  leadId    String
  role      String   // 'user' or 'assistant'
  content   String   @db.Text
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_messages")
}

model Oportunidad {
  id                  String             @id @default(cuid())
  leadId              String
  proyectoId          String
  unidadId            String?
  etapa               String   @default("NUEVO")
  probabilidad        Int                @default(0) // 0-100
  valorEstimado       Float?
  presupuesto         Float?
  fechaCierreEstimada DateTime?
  proximaAccion       String?
  fechaProximaAccion  DateTime?
  motivoPerdida       String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // Relaciones
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  unidad   Unidad?  @relation(fields: [unidadId], references: [id], onDelete: SetNull)

  @@map("oportunidades")
}

model Tarea {
  id               String   @id @default(cuid())
  titulo           String
  descripcion      String?
  fechaVencimiento DateTime
  prioridad        String   @default("MEDIA") // BAJA, MEDIA, ALTA
  estado           String   @default("PENDIENTE") // PENDIENTE, COMPLETADA
  
  leadId           String?
  usuarioId        String
  proyectoId       String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relaciones
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  usuario  User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)

  @@map("tareas")
}

model Reserva {
  id                 String            @id @default(cuid())
  unidadId           String
  leadId             String
  vendedorId         String
  fechaInicio        DateTime          @default(now())
  fechaVencimiento   DateTime
  montoSena          Float?
  estadoPago         String @default("PENDIENTE")
  documentoGenerado  String?           // URL al documento generado
  estado             String     @default("ACTIVA")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Relaciones
  unidad   Unidad @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  lead     Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vendedor User   @relation("VendedorReserva", fields: [vendedorId], references: [id], onDelete: Cascade)

  @@map("reservas")
  @@index([unidadId])
  @@index([leadId])
  @@index([vendedorId])
  @@index([estado])
  @@index([createdAt])
}

model HistorialUnidad {
  id              String   @id @default(cuid())
  unidadId        String
  usuarioId       String
  estadoAnterior  String
  estadoNuevo     String
  motivo          String?
  createdAt       DateTime @default(now())

  // Relaciones
  unidad  Unidad @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  usuario User   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("historial_unidades")
  @@index([unidadId, createdAt])
}

model Tour360 {
  id          String   @id @default(cuid())
  proyectoId  String
  unidadId    String?
  nombre      String
  escenas     String     // JSON Array of scenes with hotspots
  estado      String     @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  notasAdmin  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  unidad   Unidad?  @relation(fields: [unidadId], references: [id], onDelete: SetNull)

  @@map("tours_360")
}

// ─────────────────────────────────────────────
// NUEVOS MODELOS ADMIN (Banners, Testimonios, KYC)
// ─────────────────────────────────────────────

model Banner {
  id            String   @id @default(cuid())
  titulo        String
  tipo          String   @default("IMAGEN") // IMAGEN, VIDEO, HTML
  mediaUrl      String
  linkDestino   String?
  posicion      String   @default("HOME_TOP") // HOME_TOP, HOME_MID, LANDING, ETC
  prioridad     Int      @default(0)
  estado        String   @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO, PAUSADO
  fechaInicio   DateTime?
  fechaFin      DateTime?
  notasAdmin    String?
  creadoPorId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creadoPor     User?    @relation("BannerCreador", fields: [creadoPorId], references: [id], onDelete: SetNull)
  pago          Pago?

  @@map("banners")
}

model Testimonio {
  id            String   @id @default(cuid())
  autorNombre   String
  autorTipo     String   @default("USUARIO") // USUARIO, EMPRESA
  autorContacto String?
  texto         String
  rating        Int?     @default(5)
  mediaUrl      String?
  proyectoId    String?
  estado        String   @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  destacado     Boolean  @default(false)
  notasAdmin    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  proyecto      Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)

  @@map("testimonios")
}

model Documentacion {
  id            String   @id @default(cuid())
  tipo          String   // DNI, ESTATUTO, MUNICIPAL, FACTIBILIDAD, OTRO
  archivoUrl    String
  estado        String   @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  comentarios   String?
  
  usuarioId     String?  // Para KYC de usuario
  proyectoId    String?  // Para documentación técnica de proyecto
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usuario       User?     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  proyecto      Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@map("documentacion")
}

model Pago {
  id            String   @id @default(cuid())
  monto         Float
  moneda        String   @default("USD")
  concepto      String?
  estado        String   @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  comprobanteUrl String?
  fechaPago     DateTime @default(now())
  
  usuarioId     String
  proyectoId    String?
  bannerId      String?   @unique

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usuario       User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  proyecto      Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  banner        Banner?   @relation(fields: [bannerId], references: [id], onDelete: SetNull)

  @@map("pagos")
  @@index([usuarioId])
  @@index([proyectoId])
}

model Notificacion {
  id            String   @id @default(cuid())
  usuarioId     String   // Destinatario (puede ser admin o dev)
  tipo          String   // INFO, ALERTA, EXITO, ERROR
  titulo        String
  mensaje       String
  leido         Boolean  @default(false)
  linkAccion    String?
  createdAt     DateTime @default(now())

  usuario       User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
  @@index([usuarioId, leido])
  @@index([createdAt])
}

model Noticia {
  id            String   @id @default(cuid())
  titulo        String
  slug          String   @unique
  excerpt       String?
  contenido     String   
  categoria     String   @default("GENERAL") // TECNOLOGIA, INVERSION, MARKETING, etc.
  imagenUrl     String?
  destacada     Boolean  @default(false)
  autorId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  autor         User?    @relation("NoticiaAutor", fields: [autorId], references: [id], onDelete: SetNull)

  @@map("noticias")
}
