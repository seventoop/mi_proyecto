# Local canonical development environment (.env.local)
# App: http://localhost:5000
# Postgres host port: 5433 -> container port: 5432
# Docker container: seventoop-db
# Docker network: seventoop-net
DATABASE_URL="postgresql://usuario:password@localhost:5433/seventoop"
DIRECT_URL="postgresql://usuario:password@localhost:5433/seventoop"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:5000"

# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials -> OAuth Client ID, Web)
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI & Services
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
BANNER_AI_PROVIDER="openai"
PUSHER_APP_ID="..."
PUSHER_KEY="..."
PUSHER_SECRET="..."
PUSHER_CLUSTER="..."
NEXT_PUBLIC_PUSHER_KEY="..."
NEXT_PUBLIC_PUSHER_CLUSTER="..."

# Storage — local: "local" (public/uploads/), prod: "s3"
STORAGE_TYPE="local"
STORAGE_ACCESS_KEY="..."
STORAGE_SECRET_KEY="..."
STORAGE_BUCKET="..."
STORAGE_REGION="..."
STORAGE_ENDPOINT="..."

# Sentry
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Meta / Facebook Lead Ads
META_WEBHOOK_SECRET=""
META_WEBHOOK_VERIFY_TOKEN=""
META_ACCESS_TOKEN=""
META_PHONE_NUMBER_ID=""

# TikTok Ads
TIKTOK_WEBHOOK_SECRET=""
TIKTOK_ACCESS_TOKEN=""

# WhatsApp Business
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_WEBHOOK_SECRET=""

# Cron
CRON_SECRET=""

# Rate Limiting (Upstash Redis for Vercel/Production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Resend
RESEND_API_KEY=""

# Multi-tenancy: org that receives public leads (landing, WhatsApp, community)
# Set to the CUID of the main Organization in the DB.
# IMPORTANT: If not set, public/inbound leads will be quarantined in LeadIntake table
# instead of being created as operative Leads. No silent fallback to main org for production.
SEVENTOOP_MAIN_ORG_ID="seventoop-main"

# Paperclip AI Orchestrator
FEATURE_FLAG_PAPERCLIP="false"
FEATURE_FLAG_PAPERCLIP_REAL_CONNECTION="false"
FEATURE_FLAG_LOGICTOOP_AI_CORE="false"
FEATURE_FLAG_LOGICTOOP_AI_UI="false"
PAPERCLIP_API_URL="http://localhost:3100"
PAPERCLIP_API_KEY=""
