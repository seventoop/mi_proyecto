{
  "name": "seventoop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint:strict": "next lint --max-warnings 0",
    "check-all": "npm run typecheck && npm run build",
    "db:migrate:dev": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:migrate:status": "npx prisma migrate status",
    "db:seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "db:seed:users": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' npx ts-node --transpile-only scripts/seed-role-users.ts",
    "db:seed:projects-demo": "npx ts-node --transpile-only scripts/seed-demo-projects.ts",
    "db:studio": "npx prisma studio",
    "postinstall": "prisma generate",
    "security:check": "node scripts/security-check.js"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
